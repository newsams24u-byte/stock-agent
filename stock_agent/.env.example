# ===== WHATSAPP SETTINGS =====
# Get these from Twilio (https://www.twilio.com/)
WHATSAPP_API_KEY=your_twilio_api_key_here
WHATSAPP_PHONE=+919999999999  # Your phone number with +91

# ===== EMAIL SETTINGS =====
# For Gmail, use an App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_RECEIVER=recipient-email@gmail.com

# ===== DATABASE =====
DATABASE_URL=sqlite:///stock_agent/data/trades.db

# ===== API KEYS =====
# Optional: For financial data APIs if using premium services
FINAPI_KEY=your_api_key_here
